{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:socket_app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PATH": "${workspaceFolder}/venv/Scripts;${env:PATH}"
            },
            "preLaunchTask": "setup-dev-env",
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Python: main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PATH": "${workspaceFolder}/venv/Scripts;${env:PATH}"
            },
            "preLaunchTask": "setup-dev-env",
            "justMyCode": true
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PATH": "${workspaceFolder}/venv/Scripts;${env:PATH}"
            },
            "preLaunchTask": "setup-dev-env",
            "justMyCode": true
        }
    ]
}
